# ── Generelt ──────────────────────────────────────────────────────────────────
DASHBOARD_TITLE=Hjem
API_KEY=                                # Genereres automatisk ved første start

# ── MitID / Aula login ────────────────────────────────────────────────────────
MITID_USERNAME=                         # Telefonnummer eller brugernavn
MITID_IDENTITY=                         # Fulde navn som det står i MitID
# Yderligere konti (valgfrit):
# MITID_USERNAME_2=
# MITID_IDENTITY_2=

# ── Google Kalender (ICS) ─────────────────────────────────────────────────────
GOOGLE_CALENDAR_ICS=                    # https://calendar.google.com/calendar/ical/...
GOOGLE_CALENDAR_NAME=                   # Kalenderens navn (vises i dashboard)
# Yderligere kalendere (valgfrit):
# GOOGLE_CALENDAR_ICS_2=
# GOOGLE_CALENDAR_NAME_2=

# ── Google OAuth2 (til oprettelse/sletning af events) ─────────────────────────
GOOGLE_CLIENT_ID=                       # Fra Google Cloud Console
GOOGLE_CLIENT_SECRET=                   # Fra Google Cloud Console
GOOGLE_DEFAULT_CALENDAR_ID=primary      # Kalender-ID events oprettes i
GOOGLE_OAUTH_REFRESH_TOKEN=             # Sættes automatisk efter OAuth-login
GOOGLE_OAUTH_ACCESS_TOKEN=             # Sættes automatisk (cache)

# ── Vejr (Met.no) ─────────────────────────────────────────────────────────────
WEATHER_LAT=56.127                      # Breddegrad
WEATHER_LON=10.178                      # Længdegrad

# ── OpenRouteService (rejsetider, valgfrit) ───────────────────────────────────
ORS_API_KEY=                            # https://openrouteservice.org
ORS_ORIGIN_LAT=
ORS_ORIGIN_LON=
# ORS_DEST_1_NAME=Arbejde
# ORS_DEST_1_LAT=
# ORS_DEST_1_LON=
# ORS_DEST_1_DEFAULT=cycling-regular

# ── Spotify OAuth2 (valgfrit) ─────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=                      # Fra developer.spotify.com/dashboard
SPOTIFY_CLIENT_SECRET=                  # Fra developer.spotify.com/dashboard
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/spotify/callback
SPOTIFY_OAUTH_REFRESH_TOKEN=            # Sættes automatisk efter OAuth-login
ANTHROPIC_API_KEY=                      # https://console.anthropic.com

# -- Google Cast / Nest enheder
CAST_HOSTS=                             # f.eks. 192.168.86.123,192.168.86.124

# =============================================================================
# Familieoverblik — Konfiguration
# Kopiér denne fil til .env og udfyld dine oplysninger
# Eller brug settings-siden: http://familiekalender.local:8000/settings.html
# =============================================================================

# ── API sikkerhed ─────────────────────────────────────────────────────────────
# Genereres automatisk ved første start — kan også sættes manuelt
API_KEY=

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Titel vist i øverste venstre hjørne
DASHBOARD_TITLE=Hjem

# ── MitID / Aula login ────────────────────────────────────────────────────────
# Brugernavn = telefonnummer eller CPR du logger ind med på MitID
# Identity = dit fulde navn som det står i MitID
MITID_USERNAME=
MITID_IDENTITY=
# Tilføj flere konti hvis nødvendigt:
# MITID_USERNAME_2=
# MITID_IDENTITY_2=

# ── Google / Apple Kalender (ICS) ─────────────────────────────────────────────
# Google: Kalenderindstillinger → Integrer kalender → Offentlig adresse i iCal-format
# Apple:  Kalender → Rediger → Del kalender → Offentlig → kopiér URL (skift webcal:// til https://)
GOOGLE_CALENDAR_ICS=
GOOGLE_CALENDAR_NAME=
# GOOGLE_CALENDAR_ICS_2=
# GOOGLE_CALENDAR_NAME_2=

# ── Vejr ──────────────────────────────────────────────────────────────────────
# Koordinater for din placering — find på maps.google.com (højreklik → koordinater)
WEATHER_LAT=
WEATHER_LON=

# ── Ruter (valgfri) ───────────────────────────────────────────────────────────
# OpenRouteService API nøgle — gratis på openrouteservice.org
# ORS_API_KEY=
# ORS_ORIGIN_LAT=
# ORS_ORIGIN_LON=
# ORS_DEST_1_NAME=
# ORS_DEST_1_LAT=
# ORS_DEST_1_LON=
# ORS_DEST_1_DEFAULT=cycling-regular

# ── Anthropic API (valgfri) ───────────────────────────────────────────────────
# Forbedrer dato-parsing fra Aula-beskeder — gratis credits ved oprettelse
# console.anthropic.com
# ANTHROPIC_API_KEY=

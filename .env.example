AULA_PHPSESSID=your_phpsessid_here
AULA_CSRF_TOKEN=your_csrf_token_here
API_KEY=your_random_secret_here

# MitID account (primary)
MITID_USERNAME=your_mitid_username_here
MITID_IDENTITY=Your Full Name Here

# MitID account (optional second account)
# MITID_USERNAME_2=second_username
# MITID_IDENTITY_2=Second Full Name

# Google Calendar ICS links (public ICS from Google Calendar settings)
GOOGLE_CALENDAR_ICS_RASMUS=https://calendar.google.com/calendar/ical/your_email%40gmail.com/public/basic.ics
GOOGLE_CALENDAR_ICS_MAJA=https://calendar.google.com/calendar/ical/partner_email%40gmail.com/public/basic.ics

# Weather (met.no) — coordinates for your home address
WEATHER_LAT=56.1136
WEATHER_LON=10.1969

# OpenRouteService routing (https://openrouteservice.org — free API key)
ORS_API_KEY=your_ors_api_key_here
ORS_ORIGIN_LAT=56.113586
ORS_ORIGIN_LON=10.196946
ORS_DEST_1_NAME=Work
ORS_DEST_1_LAT=56.152004
ORS_DEST_1_LON=10.176888
ORS_DEST_1_DEFAULT=cycling-regular
ORS_DEST_2_NAME=Partner work
ORS_DEST_2_LAT=56.190518
ORS_DEST_2_LON=10.173182
ORS_DEST_2_DEFAULT=cycling-regular
ORS_DEST_3_NAME=School
ORS_DEST_3_LAT=56.115202
ORS_DEST_3_LON=10.200216
ORS_DEST_3_DEFAULT=foot-walking
